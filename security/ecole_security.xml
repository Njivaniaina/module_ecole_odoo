<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Catégorie de sécurité -->
        <record id="module_category_ecole" model="ir.module.category">
            <field name="name">Gestion École</field>
            <field name="description">Niveaux d'accès pour le module école</field>
            <field name="sequence">10</field>
        </record>

        <!-- Groupe Utilisateur (Enseignant) -->
        <record id="group_ecole_user" model="res.groups">
            <field name="name">Enseignant</field>
            <field name="category_id" ref="module_category_ecole"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Groupe Gestionnaire (Directeur) -->
        <record id="group_ecole_manager" model="res.groups">
            <field name="name">Directeur / Administrateur</field>
            <field name="category_id" ref="module_category_ecole"/>
            <field name="implied_ids" eval="[(4, ref('group_ecole_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Règles d'enregistrement (Record Rules) -->
        <record id="rule_ecole_cours_enseignant" model="ir.rule">
            <field name="name">Enseignants : voir uniquement leurs cours</field>
            <field name="model_id" ref="model_ecole_cours"/>
            <field name="groups" eval="[(4, ref('group_ecole_user'))]"/>
            <field name="domain_force">['|', ('enseignant_id.user_id', '=', user.id), ('enseignant_id', '=', False)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Règle pour le gestionnaire (voit tout) -->
        <record id="rule_ecole_cours_manager" model="ir.rule">
            <field name="name">Gestionnaire : voir tous les cours</field>
            <field name="model_id" ref="model_ecole_cours"/>
            <field name="groups" eval="[(4, ref('group_ecole_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
