<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_mes_notes" name="Mes Notes">
        <t t-call="web.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_text_block pt40 pb40" data-snippet="s_text_block">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-12">
                                <h1 class="text-center mb-4">Portail Étudiant : Mes Notes</h1>
                                
                                <t t-if="not notes">
                                    <div class="alert alert-info text-center" role="alert">
                                        Vous n'avez aucune note enregistrée pour le moment.
                                    </div>
                                </t>
                                <t t-else="">
                                    <table class="table table-striped table-hover mt-4">
                                        <thead class="thead-dark">
                                            <tr>
                                                <th>Date</th>
                                                <th>Cours</th>
                                                <th>Étudiant</th>
                                                <th>Note (/20)</th>
                                                <th>Appréciation</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="notes" t-as="n">
                                                <tr>
                                                    <td><span t-field="n.date"/></td>
                                                    <td><strong t-out="n.cours_id.name"/></td>
                                                    <td><t t-out="n.etudiant_id.name"/></td>
                                                    <td><span t-field="n.note"/></td>
                                                    <td>
                                                        <t t-if="n.appreciation == 'excellent'"><span class="badge text-bg-success">Excellent</span></t>
                                                        <t t-elif="n.appreciation == 'bien'"><span class="badge text-bg-primary">Bien</span></t>
                                                        <t t-elif="n.appreciation == 'passable'"><span class="badge text-bg-warning">Passable</span></t>
                                                        <t t-else=""><span class="badge text-bg-danger">Insuffisant</span></t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
