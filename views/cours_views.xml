<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue formulaire -->
    <record id="view_cours_form" model="ir.ui.view">
        <field name="name">ecole.cours.form</field>
        <field name="model">ecole.cours</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_ouvrir" string="Ouvrir"
                            type="object" class="btn-primary"
                            invisible="etat != 'brouillon'"/>
                    <button name="action_cloturer" string="Clôturer"
                            type="object"
                            invisible="etat != 'ouvert'"/>
                    <button name="action_brouillon" string="Remettre en brouillon"
                            type="object"
                            invisible="etat != 'cloture'"/>
                    <field name="etat" widget="statusbar"
                           statusbar_visible="brouillon,ouvert,cloture"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Intitulé du cours..."/></h1>
                        <h2><field name="code" readonly="1"/></h2>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="date_debut"/>
                            <field name="date_fin"/>
                            <field name="capacite"/>
                            <field name="nb_etudiants"/>
                            <field name="enseignant_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Étudiants inscrits">
                            <field name="etudiant_ids">
                                <tree>
                                    <field name="matricule"/>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="telephone"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue liste -->
    <record id="view_cours_list" model="ir.ui.view">
        <field name="name">ecole.cours.list</field>
        <field name="model">ecole.cours</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="nb_etudiants"/>
                <field name="capacite"/>
                <field name="enseignant_id"/>
                <field name="etat"/>
            </tree>
        </field>
    </record>

    <!-- Vue Kanban -->
    <record id="view_cours_kanban" model="ir.ui.view">
        <field name="name">ecole.cours.kanban</field>
        <field name="model">ecole.cours</field>
        <field name="arch" type="xml">
            <kanban default_group_by="etat">
                <field name="name"/>
                <field name="code"/>
                <field name="nb_etudiants"/>
                <field name="capacite"/>
                <field name="etat"/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="oe_kanban_card">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="code"/>
                            </div>
                            <div>
                                Étudiants : <field name="nb_etudiants"/> /
                                <field name="capacite"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_cours" model="ir.actions.act_window">
        <field name="name">Cours</field>
        <field name="res_model">ecole.cours</field>
        <field name="view_mode">tree,kanban,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_ecole_cours"
              name="Cours"
              parent="menu_ecole_root"
              action="action_cours"
              sequence="2"/>

</odoo>